# Supabase (Project Settings → API: Publishable + Secret; legacy anon/service_role keys not used)
# Client (Vite): publishable key only (sb_publishable_…)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only: same publishable (optional; overrides Vite value for Node without VITE_ prefix)
# SUPABASE_PUBLISHABLE_KEY=
# Server-only: secret key (sb_secret_…), never expose in the browser
SUPABASE_SECRET_KEY=

# JWT for app session after web/toss login
JWT_SECRET=

# Gemini (optional; used by Vite if present)
GEMINI_API_KEY=

# Optional: Socket.io when the web app is not served from the API origin
# VITE_BACKEND_URL=http://localhost:3000

# apps/toss — Vite dev proxy target (default http://127.0.0.1:3000). Used when VITE_API_BASE_URL is unset.
# TOSS_DEV_API_TARGET=http://127.0.0.1:3000
# VITE_USE_REMOTE_API_IN_DEV=true  # 로컬 dev에서도 강제로 VITE_API_BASE_URL/VITE_BACKEND_URL 사용

# apps/toss — production API origin (no trailing slash). Unset in dev to use same-origin + Vite proxy.
# npm run ait:build 전에 반드시 설정하세요. 비어 있으면 토스에서 로그인 시 HTML이 와 JSON 파싱 오류가 납니다.
# VITE_API_BASE_URL=https://puzzlox.com

# Socket.io (프론트 정적 호스팅과 API 도메인이 다를 때; API와 같은 호스트면 생략 가능)
# VITE_BACKEND_URL=https://puzzlox.com

# Socket.io server URL when the Toss app is served on a different origin than the API (optional in dev: Vite proxies /socket.io).
# VITE_BACKEND_URL=http://localhost:3000

# Render Web Service (예시)
# Build Command: npm ci && npm run build   (세미콜론(;) 대신 && 로 설치 실패 시 빌드 중단)
# 루트에 .npmrc 의 legacy-peer-deps 가 있어야 React 19 + @toss/tds-mobile 설치가 완료됩니다.
#
# --- Apps in Toss (ait) ---
# granite.config.ts 의 appName·brand·outdir 을 콘솔 설정과 맞춘 뒤:
#   npm run ait:build   → 저장소 루트에 {appName}.ait 생성
# 배포 API 키 등록: npx ait token add --api-key <콘솔에서 발급한 키>
# 업로드(테스트 배포): npm run ait:deploy
#   또는: npx ait deploy --location ./puzzlox.ait -m "메모"
# 샌드박스에서 로컬 번들러: npm run dev:granite (+ 로그인/API 는 npm run dev:server)
#
# Android 실기기(USB) — 개발 서버 연결:
#   1) USB 디버깅 ON, PC에 `adb`(platform-tools) PATH 등록
#   2) npm run android:reverse
#   3) 터미널 A: npm run dev:granite  /  터미널 B: npm run dev:server
#   4) 샌드박스 앱에서 intoss://puzzleox 실행
# Wi‑Fi만: PC와 폰이 같은 Wi‑Fi일 때 (granite.config.ts 가 읽음)
#   TOSS_GRANITE_WEB_HOST=192.168.x.x
#   TOSS_GRANITE_WEB_PORT=5174
# 원격 터널(trycloudflare 등): host 는 터널 도메인, port 는 443
#   TOSS_GRANITE_WEB_HOST=xxxx.trycloudflare.com
#   TOSS_GRANITE_WEB_PORT=443
# 출근·USB 기본값은 설정 없이 localhost:5174 (adb reverse 권장)
#
# @toss/tds-mobile 은 일반 PC 브라우저에서 동작이 제한될 수 있어, UI 확인은 샌드박스 앱을 권장합니다.

# Apps in Toss — partner API (토스 로그인: generate-token, login-me)
# Default host: apps-in-toss-api.toss.im
# TOSS_API_HOST=apps-in-toss-api.toss.im

# mTLS client certificate for partner API (토스 로그인 필수 — 서버 파일 시스템의 PEM 경로)
# 둘 다 비우면 /api/auth/toss/login 이 "mTLS 가 설정되지 않았습니다" 로 실패합니다.
# 인증서 갱신 후에는 cert·key 한 쌍·TOSS_MTLS_CA_PATH(안내 시)를 다시 맞추세요.
# TOSS_MTLS_CERT_PATH=
# TOSS_MTLS_KEY_PATH=
# TOSS_MTLS_CA_PATH=

# --- Android TWA (Trusted Web Activity) — Digital Asset Links on the API server ---
# 설정 시 GET https://<도메인>/.well-known/assetlinks.json 이 JSON을 반환합니다. 미설정이면 404.
# 앱의 applicationId(예: com.puzzlox.app)와 Play 업로드 키 SHA-256 지문을 넣으세요. 여러 지문은 쉼표 또는 공백으로 구분.
# ANDROID_TWA_PACKAGE_NAME=com.puzzlox.app
# ANDROID_TWA_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...
